# ── Server ──────────────────────────────────────────────────────
PORT=5100
NODE_ENV=production
JWT_SECRET=change-me-long-random-string

# ── PostgreSQL ──────────────────────────────────────────────────
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=novuswork
PGUSER=novus
PGPASSWORD=change-me

# ── Admin panel ─────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=change-me
ADMIN_EMAIL=admin@novuswork.com

# ── Google Sign-In (provide your OAuth Client ID) ───────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# ── PayPal ($5 profile activation) ──────────────────────────────
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
ACTIVATION_PRICE=5.00

# ── Email (Brevo HTTPS API) ─────────────────────────────────────
BREVO_API_KEY=
CONTACT_FROM=your-email@example.com
CONTACT_FROM_NAME=NovusWork
CONTACT_TO=your-email@example.com

# ── Dev helpers (never enable in production) ────────────────────
DEV_LOGIN=false

# ── AI Assistant (Qwen 2.5 7B via Ollama) ───────────────────────
OLLAMA_URL=http://127.0.0.1:11434
